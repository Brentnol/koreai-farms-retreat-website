* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: #f8f4ec;
  color: #1c1917;
}

a {
  color: inherit;
  text-decoration: none;
}

.site {
  min-height: 100vh;
  overflow-x: hidden;
}

.container {
  width: min(1180px, calc(100% - 40px));
  margin: 0 auto;
}

.header {
  position: fixed;
  inset: 0 0 auto 0;
  z-index: 50;
  background: linear-gradient(90deg, rgba(28,25,23,0.92), rgba(6,78,59,0.78));
  border-bottom: 1px solid rgba(255,255,255,0.15);
  backdrop-filter: blur(18px);
}

.header-inner {
  width: min(1180px, calc(100% - 40px));
  margin: 0 auto;
  min-height: 82px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand-logo {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  overflow: hidden;
  background: #fff7ed;
  box-shadow: 0 18px 50px rgba(0,0,0,0.18);
  border: 1px solid rgba(255,255,255,0.25);
}

.brand-logo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.brand-koreai {
  display: block;
  color: #d1fae5;
  letter-spacing: 0.22em;
  font-size: 14px;
  font-weight: 800;
}

.brand-subtitle {
  display: block;
  color: #d6d3d1;
  font-size: 12px;
  margin-top: 2px;
}

.desktop-nav {
  display: flex;
  align-items: center;
  gap: 30px;
  color: #e7e5e4;
  font-size: 15px;
}

.desktop-nav a:hover {
  color: #a7f3d0;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  border: 0;
  border-radius: 999px;
  background: linear-gradient(135deg, #047857, #d97706);
  color: white;
  padding: 13px 22px;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
}

.button:hover {
  background: #047857;
  transform: translateY(-1px);
}

.button-large {
  padding: 16px 28px;
}

.button-outline {
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.4);
}

.button-outline:hover {
  background: white;
  color: #1c1917;
}

.button-white {
  background: white;
  color: #065f46;
}

.button-white:hover {
  background: #ecfdf5;
  color: #064e3b;
}

.mobile-menu-button {
  display: none;
  background: transparent;
  color: white;
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 14px;
  padding: 9px;
}

.mobile-nav {
  display: none;
}

.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  padding: 130px 0 90px;
  color: white;
  background: #1c1917;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 12% 8%, rgba(16,185,129,0.35), transparent 32%),
    linear-gradient(120deg, rgba(28,25,23,0.78), rgba(28,25,23,0.48)),
    url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1800&q=80");
  background-size: cover;
  background-position: center;
}

.hero-gradient {
  position: absolute;
  inset: auto 0 0 0;
  height: 170px;
  background: linear-gradient(to top, #fafaf7, transparent);
}

.hero-grid {
  position: relative;
  display: grid;
  align-items: center;
  gap: 56px;
  grid-template-columns: 1.1fr 0.9fr;
}

.domain-pill {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.22);
  background: rgba(255,255,255,0.12);
  padding: 8px 16px;
  color: #d1fae5;
  backdrop-filter: blur(14px);
  margin-bottom: 28px;
}

.domain-pill img {
  width: 38px;
  height: 38px;
  border-radius: 999px;
  object-fit: cover;
  background: #fff7ed;
}

h1, h2, h3, p {
  margin-top: 0;
}

.hero h1 {
  max-width: 830px;
  font-size: clamp(48px, 7vw, 86px);
  line-height: 0.98;
  letter-spacing: -0.05em;
  margin-bottom: 28px;
}

.hero-copy {
  max-width: 720px;
  color: #f5f5f4;
  font-size: clamp(18px, 2vw, 22px);
  line-height: 1.7;
  margin-bottom: 38px;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.snapshot-card {
  border-radius: 34px;
  border: 1px solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.1);
  padding: 20px;
  box-shadow: 0 30px 90px rgba(0,0,0,0.32);
  backdrop-filter: blur(18px);
}

.snapshot-inner {
  border-radius: 26px;
  background: rgba(28,25,23,0.58);
  padding: 28px;
}

.eyebrow {
  color: #047857;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.eyebrow.light {
  color: #a7f3d0;
}

.stats {
  display: grid;
  gap: 16px;
}

.stat {
  border-radius: 24px;
  background: rgba(255,255,255,0.1);
  padding: 22px;
}

.stat p {
  color: white;
  font-size: 44px;
  line-height: 1;
  font-weight: 800;
  margin-bottom: 6px;
}

.stat span {
  color: #d6d3d1;
  font-size: 14px;
}

.note {
  margin-top: 18px;
  display: flex;
  gap: 14px;
  border-radius: 24px;
  background: rgba(16,185,129,0.16);
  color: #ecfdf5;
  padding: 20px;
}

.note p {
  margin-bottom: 0;
  line-height: 1.6;
  font-size: 14px;
}

.section {
  padding: 100px 0;
}

.section-white {
  background: white;
}

.two-column {
  display: grid;
  grid-template-columns: 0.8fr 1.2fr;
  gap: 56px;
}

h2 {
  font-size: clamp(38px, 4.5vw, 58px);
  line-height: 1.05;
  letter-spacing: -0.04em;
  margin-bottom: 24px;
}

.body-copy {
  color: #57534e;
  font-size: 18px;
  line-height: 1.8;
}

.section-heading {
  max-width: 760px;
}

.cards-grid {
  margin-top: 56px;
  display: grid;
  gap: 22px;
  grid-template-columns: repeat(4, 1fr);
}

.feature-card {
  height: 100%;
  border: 1px solid #e7e5e4;
  background: #fafaf7;
  border-radius: 32px;
  padding: 30px;
  box-shadow: 0 18px 50px rgba(28,25,23,0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.feature-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 26px 60px rgba(28,25,23,0.1);
}

.icon-wrap {
  width: 58px;
  height: 58px;
  border-radius: 20px;
  background: #d1fae5;
  color: #047857;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
}

.feature-card h3 {
  font-size: 21px;
  margin-bottom: 14px;
}

.feature-card p {
  color: #57534e;
  line-height: 1.7;
  margin-bottom: 0;
}

.vision-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 42px;
  align-items: center;
}

.vision-image {
  min-height: 500px;
  border-radius: 42px;
  background:
    linear-gradient(rgba(28,25,23,0.12),rgba(28,25,23,0.12)),
    url("https://images.unsplash.com/photo-1475776408506-9a5371e7a068?auto=format&fit=crop&w=1400&q=80");
  background-size: cover;
  background-position: center;
  box-shadow: 0 30px 80px rgba(28,25,23,0.18);
}

.vision-panel {
  border-radius: 42px;
  background: #1c1917;
  color: white;
  padding: 50px;
}

.vision-panel > p:not(.eyebrow) {
  color: #e7e5e4;
  font-size: 18px;
  line-height: 1.8;
}

.vision-mini-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 32px;
}

.vision-mini-grid > div {
  border-radius: 26px;
  background: rgba(255,255,255,0.1);
  padding: 22px;
}

.vision-mini-grid svg {
  color: #6ee7b7;
}

.vision-mini-grid h3 {
  margin: 14px 0 8px;
}

.vision-mini-grid p {
  color: #d6d3d1;
  font-size: 14px;
  line-height: 1.6;
  margin-bottom: 0;
}

.cta-band {
  background: linear-gradient(135deg, #064e3b, #1c1917 58%, #92400e);
  color: white;
  padding: 78px 0;
}

.cta-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 32px;
}

.cta-inner h2 {
  max-width: 760px;
  margin-bottom: 0;
}

.contact-grid {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 46px;
}

.contact-list {
  margin-top: 32px;
  display: grid;
  gap: 16px;
  color: #57534e;
}

.contact-list p {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0;
}

.contact-list svg {
  color: #047857;
  flex: 0 0 auto;
}

.contact-form {
  border: 1px solid #e7e5e4;
  background: white;
  border-radius: 34px;
  padding: 34px;
  box-shadow: 0 26px 80px rgba(28,25,23,0.12);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}

label {
  display: block;
  color: #44403c;
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 18px;
}

input,
select,
textarea {
  display: block;
  width: 100%;
  margin-top: 9px;
  border: 1px solid #e7e5e4;
  border-radius: 18px;
  background: #fafaf7;
  padding: 14px 16px;
  font: inherit;
  color: #1c1917;
  outline: none;
}

input:focus,
select:focus,
textarea:focus {
  border-color: #059669;
}

textarea {
  min-height: 150px;
  resize: vertical;
}

.submit-button {
  width: 100%;
  padding: 17px 22px;
  font-size: 16px;
}

.form-note {
  text-align: center;
  color: #78716c;
  font-size: 12px;
  margin: 14px 0 0;
}

.footer {
  border-top: 1px solid #e7e5e4;
  background: white;
  padding: 32px 0;
}

.footer-inner {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  color: #57534e;
  font-size: 14px;
}

.footer-inner p {
  margin: 0;
}

@media (max-width: 980px) {
  .hero-grid,
  .two-column,
  .vision-grid,
  .contact-grid {
    grid-template-columns: 1fr;
  }

  .cards-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .snapshot-card {
    max-width: 560px;
  }
}

@media (max-width: 760px) {
  .desktop-nav,
  .header-button {
    display: none;
  }

  .mobile-menu-button {
    display: inline-flex;
  }

  .mobile-nav {
    display: grid;
    gap: 10px;
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: 0 0 18px;
    color: white;
  }

  .mobile-nav a:not(.button) {
    padding: 12px;
    border-radius: 14px;
  }

  .mobile-nav a:not(.button):hover {
    background: rgba(255,255,255,0.1);
  }

  .header-inner {
    min-height: 74px;
  }

  .hero {
    padding-top: 120px;
  }

  .hero h1 {
    font-size: 48px;
  }

  .hero-actions,
  .cta-inner,
  .footer-inner {
    align-items: stretch;
    flex-direction: column;
  }

  .button {
    width: 100%;
  }

  .cards-grid,
  .vision-mini-grid,
  .form-row {
    grid-template-columns: 1fr;
  }

  .section {
    padding: 76px 0;
  }

  .vision-panel,
  .contact-form {
    padding: 28px;
  }

  .vision-image {
    min-height: 360px;
  }
}
